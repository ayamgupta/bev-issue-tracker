# Copy this file to .env.local for local dev, and set the same keys as
# repository secrets / GitHub Actions variables for deployment.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Cloudflare Turnstile site key (public, safe to ship to the browser).
# The matching TURNSTILE_SECRET_KEY is set as a Supabase Edge Function
# secret instead — see supabase/functions/submit-report.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
